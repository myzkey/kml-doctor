{
  "name": "kml-doctor-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/cli",
    "lint": "eslint --config packages/config/eslint/root.js \"packages/*/src/**/*.ts\"",
    "format": "prettier --config packages/config/prettier/base.json --check .",
    "format:write": "prettier --config packages/config/prettier/base.json --write .",
    "test": "vitest run --config packages/config/vitest/root.ts",
    "check": "pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@kml-doctor/config": "workspace:*",
    "@types/node": "^24.13.2",
    "eslint": "^10.0.1",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10"
  }
}
